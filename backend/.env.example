# Copy this file to backend/.env (same folder as this example) and paste your key.
# Get a key: https://aistudio.google.com/apikey
# Then restart (or use backend\run_api.bat — default port 8889):
# python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8889
GEMINI_API_KEY=
# Clean floor plan image (walls + doors only). Must support image output. Default: gemini-3.1-flash-image-preview
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# REST API version for google-genai (preview models use v1beta)
GEMINI_API_VERSION=v1beta

# Production CORS allow-list (comma-separated).
# Example:
# CORS_ORIGINS=https://your-vercel-app.vercel.app,https://www.yourdomain.com
# If omitted, API allows all origins (good for local dev, not recommended for production).
# CORS_ORIGINS=

# Supabase (optional, for hosted persistence/auth integration)
# Project URL from Supabase Dashboard → Settings → API
SUPABASE_URL=https://lbfmovufbvibharqjcrs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Optional for frontend/public clients only (do not use in backend writes):
# SUPABASE_ANON_KEY=

# Redis (optional, used for cache/realtime helpers)
# Example: redis://default:password@host:6379/0
REDIS_URL=

# Request audit/reconciliation tracking
# 1 = enabled, 0 = disabled
ENABLE_REQUEST_AUDIT=1
# Set in production so hashes are stable and private to your environment
AUDIT_HASH_SALT=
# Trust X-Forwarded-For / X-Real-IP headers from proxy (Render/Cloudflare/etc)
TRUST_PROXY_HEADERS=1

# Optional: use Vertex AI instead of API key
# GEMINI_USE_VERTEX=1
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
